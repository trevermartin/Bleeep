{
  "functions": {
    "app/api/process/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/reprocess/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/stripe/webhook/route.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
