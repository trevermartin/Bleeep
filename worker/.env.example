# ── Bleeep Railway worker environment ──────────────────────────────────────
# Copy to .env for local runs. On Railway, set these as service variables.

# Supabase service-role access (bypasses RLS — server-only, never ship to browser).
# NOTE: the worker uses SUPABASE_URL (not NEXT_PUBLIC_SUPABASE_URL).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vocal isolation (MVSEP). Same key the Vercel app used.
MVSEP_API_KEY=your-mvsep-api-key

# Transcription (AssemblyAI).
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# Lyrics hint (Genius official API Bearer token). Moved here because Genius
# returns HTTP 403 to Vercel's IPs; Railway can reach it.
GENIUS_API_KEY=your-genius-bearer-token

# Shared secret required in the `x-worker-secret` header on POST /genius-lyrics.
# Must match the WORKER_SECRET set on Vercel.
WORKER_SECRET=generate-a-long-random-string

# Optional — defaults shown.
PORT=8080
POLL_INTERVAL_MS=4000
